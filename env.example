# 環境變數設定範例

# 複製本檔案為 .env 並填入實際的值
# cp env.example .env

# API 端點（如有使用後端 API）
# VITE_API_URL=https://api.example.com

# 地圖相關設定（如需要特殊地圖服務的 Token）
# VITE_MAPBOX_TOKEN=your_mapbox_token_here

# 其他設定
# VITE_APP_NAME=台灣不義遺址故事地圖
# VITE_APP_VERSION=1.0.0

# 注意：
# 1. VITE_ 開頭的變數會暴露在前端程式碼中
# 2. 敏感資訊（API keys、secrets）請勿提交到 Git
# 3. .env 檔案已加入 .gitignore，不會被提交
